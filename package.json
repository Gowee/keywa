{
  "name": "keywa",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "format": "prettier --write '*.{json,js}' 'src/**/*.{js,ts}'",
