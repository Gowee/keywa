name = "keywa"
main = "src/index.ts"
compatibility_date = "2024-04-03"

[vars]
TIMEOUT_SECONDS = "3600"  # 1 hour, configurable
# DISABLE_TELEGRAM_LOGIN = "true"  # uncomment to disable Telegram login

[[d1_databases]]
binding = "DB"
database_name = "keywa"
database_id = "TO_BE_FILLED"
# To create: pnpm wrangler d1 create keywa

[[durable_objects.bindings]]
name = "KEY_SESSION_DO"
class_name = "KeySessionDO"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["KeySessionDO"]

[[ratelimits]]
name = "LOGIN_RATE_LIMIT"
namespace_id = "1"
  [ratelimits.simple]
  limit = 1
  period = 60

[[ratelimits]]
name = "KEY_REQUEST_RATE_LIMIT"
namespace_id = "2"
  [ratelimits.simple]
  limit = 10
  period = 60

# Required secrets (set via `echo VALUE | pnpm wrangler secret put NAME`):
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_CHAT_ID
# - ADMIN_TOKEN             (arbitrary secret string for admin endpoints)
#
# Optional secrets:
# - TELEGRAM_WEBHOOK_SECRET   (if set, verifies X-Telegram-Bot-Api-Secret-Token header)
